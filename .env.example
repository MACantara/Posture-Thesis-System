# =============================================================================
# Posture Thesis System - Environment Configuration
# Copy this file to .env and adjust values as needed
#
# Only SENSITIVE variables are listed here.
# All other config defaults are in backend/app/config.py and can be
# overridden by setting environment variables if needed.
# =============================================================================

# --- General ---
# Secret key for JWT signing — REQUIRED in production
# Generate a secure key with:  python -m app.config generate-secret
SECRET_KEY=change-me-to-a-random-secret-key

# --- Database ---
# SQLite database file path (contains user data)
DATABASE_PATH=posture.db
