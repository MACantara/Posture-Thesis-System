# =============================================================================
# Backend Environment Configuration
# Copy this file to .env and adjust values as needed
#
# All config defaults are in app/config.py.
# Override any of them by setting the environment variable here.
# =============================================================================

# --- General ---
# Secret key for JWT signing — REQUIRED in production
# Generate a secure key with:  python -m app.config generate-secret
SECRET_KEY=change-me-to-a-random-secret-key

# --- Database ---
# Database backend: "sqlite" for local dev, "postgresql" for Railway/production
DB_BACKEND=sqlite

# SQLite database file path (used when DB_BACKEND=sqlite)
DATABASE_PATH=posture.db

# PostgreSQL connection URL (used when DB_BACKEND=postgresql)
# On Railway, this is auto-provided when you add a PostgreSQL service
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- CORS ---
# Comma-separated list of allowed origins for cross-origin requests
# For separate frontend deployment, set to the frontend URL
CORS_ORIGINS=http://localhost:5173

# --- Server ---
# Host and port for the FastAPI server (Railway sets PORT automatically)
# HOST=0.0.0.0
# PORT=8000
# WORKERS=1

# --- Frontend Static Files ---
# Path to built React dist directory (only needed when serving frontend from backend)
# FRONTEND_DIST_PATH=../frontend/dist

# --- Hardware Config ---
# I2C_BUS=1
# MPU6050_ADDRESS=0x68
# SERVO_GPIO_PIN=18
# VIBRATOR_GPIO_PIN=23
# SENSOR_SAMPLE_RATE=10
# CALIBRATION_OFFSETS_PATH=config/calibration.json

# --- Posture Detection Thresholds (degrees from neutral) ---
# POSTURE_ANGLE_THRESHOLD_GOOD=10
# POSTURE_ANGLE_THRESHOLD_WARNING=20
