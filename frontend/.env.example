# =============================================================================
# Frontend Environment Configuration
# Copy this file to .env and adjust values as needed
#
# These variables are embedded at build time (VITE_ prefix required)
# =============================================================================

# Backend API URL — set to your backend Railway service URL in production
# Local dev: http://localhost:8000
# Railway:   https://your-backend-service.railway.app
VITE_API_URL=http://localhost:8000

# Backend WebSocket URL — for real-time sensor data
# Local dev: ws://localhost:8000
# Railway:   wss://your-backend-service.railway.app
VITE_WS_URL=ws://localhost:8000
