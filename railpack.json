{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.13",
    "node": "22"
  },
  "steps": {
    "python-install": {
      "commands": [
        { "src": "backend/requirements.txt", "dest": "requirements.txt" },
        "pip install -r requirements.txt"
      ]
    },
    "frontend-install": {
      "commands": [
        { "src": "frontend/package.json", "dest": "frontend/package.json" },
        { "src": "frontend/package-lock.json", "dest": "frontend/package-lock.json" },
        "cd frontend && npm install"
      ]
    },
    "frontend-build": {
      "inputs": [{ "step": "frontend-install" }],
      "commands": [
        { "src": "frontend", "dest": "frontend" },
        "cd frontend && npm run build"
      ]
    }
  },
  "deploy": {
    "inputs": [
      { "step": "python-install" },
      { "step": "frontend-build" },
      { "src": "backend/app", "dest": "app" },
      { "src": "backend/run.py", "dest": "run.py" }
    ],
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "variables": {
      "FRONTEND_DIST_PATH": "frontend/dist"
    }
  }
}
